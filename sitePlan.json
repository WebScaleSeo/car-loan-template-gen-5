      "componentDefinitions": {
        "aboutHero": {
          "purpose": "Introduces the About page with a compelling narrative about DriveWay Finance's purpose and commitment to car buyers.",
          "dataSchema": {
            "type": "object",
            "properties": {
              "headline": {
                "type": "string",
