              "loanTypes"
            ]
          }
        },
        "testimonialShowcase": {
          "purpose": "Builds trust and social proof by sharing real customer experiences and satisfaction with the car loan process.",
          "dataSchema": {
            "type": "object",
            "properties": {
              "sectionTitle": {
                "type": "string",
                "description": "Heading for testimonial section"
              },
              "sectionSubtitle": {
                "type": "string",
                "description": "Brief intro about customer satisfaction"
              },
              "testimonials": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "quote": {
                      "type": "string",
