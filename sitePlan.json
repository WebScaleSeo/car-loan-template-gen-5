    "about": {
      "seo": {
        "title": "About DriveWay Finance — Our Mission & Approach",
        "metaDescription": "Learn about DriveWay Finance's mission to make car loans accessible, transparent, and affordable. Discover our approach, values, and commitment to your success."
      },
      "componentOrder": [
