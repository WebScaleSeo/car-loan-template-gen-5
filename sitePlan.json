  "pages": {
    "home": {
      "seo": {
        "title": "DriveWay Finance — Affordable Car Loans Made Simple",
        "metaDescription": "Get behind the wheel faster with DriveWay Finance. Competitive car loan rates, a streamlined application, and dedicated support to help you drive away happy."
      },
      "componentOrder": [
        "heroSection",
        "keyBenefits",
        "howItWorks",
        "loanTypesOverview",
        "testimonialShowcase",
        "whyChooseUs",
        "homeFaqPreview",
        "homeCtaBanner"
      ],
      "componentDefinitions": {
        "heroSection": {
          "purpose": "Immediately communicates the core value proposition — helping visitors secure affordable car loans — and drives them to take the first step toward getting a quote.",
          "dataSchema": {
            "type": "object",
            "properties": {
              "headline": {
                "type": "string",
                "description": "Bold, attention-grabbing headline about getting a car loan"
              },
              "subheadline": {
                "type": "string",
                "description": "Supporting sentence expanding on the promise of better rates and simple process"
              },
              "ctaButtonText": {
                "type": "string",
                "description": "Primary CTA button label (e.g., 'Get Your Free Quote')"
              },
              "ctaButtonUrl": {
                "type": "string",
                "description": "URL for CTA button — must be /contact"
              },
              "secondaryCtaText": {
                "type": "string",
                "description": "Secondary link text (e.g., 'Learn How It Works')"
              },
              "secondaryCtaUrl": {
                "type": "string",
                "description": "URL for secondary link — must be /about"
              }
            },
            "required": [
              "headline",
              "subheadline",
              "ctaButtonText",
              "ctaButtonUrl",
              "secondaryCtaText",
              "secondaryCtaUrl"
            ]
          }
        },
        "keyBenefits": {
          "purpose": "Highlights the primary advantages of choosing DriveWay Finance for a car loan — such as competitive rates, flexible terms, and fast approval — building immediate confidence.",
          "dataSchema": {
            "type": "object",
            "properties": {
              "sectionTitle": {
                "type": "string",
                "description": "Heading for the benefits section"
              },
              "sectionSubtitle": {
                "type": "string",
                "description": "Brief intro text for the benefits"
              },
              "benefits": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "iconName": {
                      "type": "string",
                      "description": "Icon identifier (e.g., 'percent', 'clock', 'shield')"
                    },
                    "title": {
                      "type": "string",
                      "description": "Benefit title"
                    },
                    "description": {
                      "type": "string",
                      "description": "One-to-two sentence description of this benefit"
                    }
                  },
                  "required": [
                    "iconName",
                    "title",
                    "description"
                  ]
                }
              }
            },
            "required": [
              "sectionTitle",
              "sectionSubtitle",
              "benefits"
            ]
          }
        },
        "howItWorks": {
          "purpose": "Explains the straightforward car loan application process in clear sequential steps so visitors know exactly what to expect.",
          "dataSchema": {
            "type": "object",
            "properties": {
              "sectionTitle": {
                "type": "string",
                "description": "Heading like 'How It Works'"
              },
              "sectionSubtitle": {
                "type": "string",
                "description": "Brief explanatory intro"
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "stepNumber": {
                      "type": "string",
                      "description": "Step number (e.g., '01')"
                    },
                    "title": {
                      "type": "string",
                      "description": "Short title for this step"
                    },
                    "description": {
                      "type": "string",
                      "description": "Explanation of what happens in this step"
                    }
                  },
                  "required": [
                    "stepNumber",
                    "title",
                    "description"
                  ]
                }
              },
              "ctaText": {
                "type": "string",
                "description": "CTA button text after steps"
              },
              "ctaUrl": {
                "type": "string",
                "description": "CTA button URL — must be /contact"
              }
            },
            "required": [
              "sectionTitle",
              "sectionSubtitle",
              "steps",
              "ctaText",
              "ctaUrl"
            ]
          }
        },
        "loanTypesOverview": {
          "purpose": "Showcases the different types of car loans available — new car, used car, refinancing — so visitors can find the option that fits their situation.",
          "dataSchema": {
            "type": "object",
            "properties": {
              "sectionTitle": {
                "type": "string",
                "description": "Heading for loan types section"
              },
              "sectionSubtitle": {
                "type": "string",
                "description": "Brief intro about loan flexibility"
              },
              "loanTypes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "iconName": {
                      "type": "string",
                      "description": "Icon identifier (e.g., 'car', 'refresh', 'key')"
                    },
                    "title": {
                      "type": "string",
                      "description": "Loan type name (e.g., 'New Car Loans')"
                    },
                    "description": {
                      "type": "string",
                      "description": "Description of this loan type and who it's for"
                    },
                    "ctaText": {
                      "type": "string",
                      "description": "Link text like 'Learn More'"
                    },
                    "ctaUrl": {
                      "type": "string",
                      "description": "URL — must be /contact"
                    }
                  },
                  "required": [
                    "iconName",
                    "title",
                    "description",
                    "ctaText",
                    "ctaUrl"
                  ]
                }
              }
            },
            "required": [
              "sectionTitle",
